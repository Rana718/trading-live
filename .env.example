# Copy this file to .env and fill in your values
# IMPORTANT: For operator-editable coin/news/TradingView settings, use runtime_settings.json instead

# YouTube streaming credentials
YOUTUBE_STREAM_KEY=your_stream_key_here

# TTS engine (Edge TTS is recommended on Windows 10 VPS)
TTS_ENGINE=edge

# Edge TTS voice settings (good Japanese production defaults)
EDGE_TTS_VOICE=ja-JP-NanamiNeural
EDGE_TTS_RATE=+0%
EDGE_TTS_VOLUME=+0%

# Configuration files
RUNTIME_SETTINGS_FILE=runtime_settings.json

# Market data source: 'coingecko' (default, free) or 'binance' (real-time crypto)
CHART_SOURCE=coingecko

# Optional: Binance API key (leave empty if using CoinGecko only)
BINANCE_API_KEY=

# TradingView widget display (optional; requires browser automation for video capture)
USE_TRADINGVIEW_WIDGET=false
TRADINGVIEW_SYMBOL=XRPJPY

# Timing (seconds)
SYMBOL_ROTATE_SEC=300
CHART_REFRESH_SEC=60
NEWS_INTERVAL_SEC=300

# Video dimensions
WIDTH=1280
HEIGHT=720
FPS=30

# Fallback coin (if runtime_settings.json is missing or empty)
COIN_ID=ripple
COIN_SYMBOL=XRP/JPY
VS_CURRENCY=jpy
